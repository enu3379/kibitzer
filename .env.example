# Copy this file to .env and fill in credentials. Never commit real API keys.
# .env is loaded automatically on every server start (terminal or LaunchAgent),
# so keys are set ONCE here and never touched during day-to-day operation.

# Optional exact-origin override. The checked-in manifest has a stable unpacked
# development ID already; set this only for a different development build or a
# production Web Store ID. Separate multiple IDs with a comma.
# KIBITZER_EXTENSION_IDS=

# Ollama Cloud API key for Tier 1 (configs/default.yaml references this exact
# name). Create one in your ollama.com account settings.
ollama1=

# Ollama Cloud API key for Tier 2. Using the same key as ollama1 is fine.
ollama2=

# Optional third key. When two or more of ollama1/2/3 are set, each tier
# rotates its calls across all of them (see api_key_pool_envs in
# configs/default.yaml) and the rest act as automatic fallbacks. With only
# ollama1/ollama2 set, this one is simply skipped.
ollama3=

# Optional overrides when not using configs/models.local.yaml.
# TIER1_BASE_URL=
# TIER2_BASE_URL=
