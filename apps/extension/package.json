{
  "name": "kibitzer-extension",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "build": "npm run ports:check && npm run assets:check && npm run test && node build.mjs",
    "watch": "node build.mjs --watch",
    "test": "node --experimental-strip-types --test && npm run typecheck && npm run typecheck:test",
    "assets:check": "node scripts/checkProviderAssets.mjs",
    "ports:generate": "node scripts/generatePortCandidates.mjs",
    "ports:check": "node scripts/generatePortCandidates.mjs --check"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@huggingface/tokenizers": "0.1.3",
    "onnxruntime-web": "1.27.0"
  }
}
